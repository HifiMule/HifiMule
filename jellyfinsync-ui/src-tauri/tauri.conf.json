{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JellyfinSync",
  "version": "0.1.0",
  "identifier": "com.alexi.jellyfinsync",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build --prefix jellyfinsync-ui && node scripts/prepare-sidecar.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "JellyfinSync Hub",
        "width": 1024,
        "height": 768,
        "visible": false,
        "center": true
      },
      {
        "label": "splashscreen",
        "title": "JellyfinSync Starting...",
        "width": 400,
        "height": 500,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": true,
        "url": "/splashscreen.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "sidecars/jellyfinsync-daemon"
    ],
    "windows": {
      "wix": {
        "fragmentPaths": ["wix/startup-fragment.wxs"],
        "componentGroupRefs": ["StartupRegistryGroup"]
      },
      "nsis": {
        "installerHooks": "nsis/hooks.nsh"
      }
    }
  }
}