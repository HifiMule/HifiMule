<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Fragment>
    <!--
      Register jellyfinsync-daemon as a startup application via Registry Run key.
      Runs in the user's interactive session (HKCU) for full tray icon support.
      WiX automatically removes the registry entry on uninstall.
    -->
    <ComponentGroup Id="StartupRegistryGroup">
      <Component Id="StartupRegistryComponent"
                 Directory="INSTALLDIR"
                 Guid="1ba6130d-4fab-4dd0-b5cb-35477b1b5f4e">
        <RegistryValue
          Root="HKCU"
          Key="Software\Microsoft\Windows\CurrentVersion\Run"
          Name="JellyfinSync"
          Type="string"
          Value="[INSTALLDIR]jellyfinsync-daemon.exe"
          KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
